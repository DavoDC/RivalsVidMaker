# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env

# Pytest
.pytest_cache/
.coverage
htmlcov/

# Runtime - user provides these, not tracked
dependencies/ffmpeg/
dependencies/*.exe

# Claude Code
.claude/

# Local state log (machine-specific, not committed)
data/state.json
*.log

# Temporary cache backup (created during full rescans, delete when confirmed)
data/cache_bak/

# Dedup frame temp files (created and deleted during each run)
data/dedup_tmp/

# Terminal export logs (one-off, not committed)
data/logs/*.txt

# YouTube OAuth credentials - never commit these
config/token.json
config/client_secret_*.json

# Analysis output is committed (timestamped reports)
